{
  "info": {
    "name": "Online Bookstore API",
    "_postman_id": "6599c7f1-4a0b-42e5-9a3a-9cb0f7dc4d11",
    "description": "Postman collection for the corrected Online Bookstore API contract.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Amira Reader\",\n  \"email\": \"amira.reader@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{baseUrl}}/users/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json.token) { pm.environment.set('jwt_token', json.token); }",
                  "if (json.user && json.user.id) { pm.environment.set('userId', json.user.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@pageturn.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{baseUrl}}/users/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.environment.set('jwt_token', json.token);",
                  "if (json.user && json.user.id) { pm.environment.set('userId', json.user.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "Get Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories" }
        },
        {
          "name": "Get Books",
          "request": { "method": "GET", "url": "{{baseUrl}}/books?page=1&limit=12&sort=price_desc" }
        },
        {
          "name": "Get Book Detail",
          "request": { "method": "GET", "url": "{{baseUrl}}/books/{{bookId}}" }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"book_id\": {{bookId}},\n  \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/cart/items"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.item && json.item.cart_item_id) { pm.environment.set('cartItemId', json.item.cart_item_id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            },
            "url": "{{baseUrl}}/cart/items/{{cartItemId}}"
          }
        },
        {
          "name": "Delete Cart Item",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": "{{baseUrl}}/cart/items/{{cartItemId}}"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipping_address\": \"Amira Reader, 12 Palm Street, Doha, Qatar\"\n}"
            },
            "url": "{{baseUrl}}/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.order_id) { pm.environment.set('orderId', json.order_id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": "{{baseUrl}}/orders"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "jwt_token", "value": "" },
    { "key": "bookId", "value": "1" },
    { "key": "cartItemId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "userId", "value": "1" }
  ]
}
